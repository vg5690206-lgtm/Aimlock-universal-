-- ═══════════════════════════════════════════════════════════════
RunService.RenderStepped:Connect(function(dt)
    updateDynamicSize(dt)
end)

local monitorTimer = 0
RunService.Heartbeat:Connect(function(dt)
    monitorTimer = monitorTimer + dt
    if monitorTimer >= 0.5 then
        monitorTimer = 0
        monitorNewPrompts()
    end
end)


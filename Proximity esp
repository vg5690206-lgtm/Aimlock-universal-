local function makeTextBox(parent, placeholder, name)
    local th = T()
    local b = Instance.new("TextBox")
    b.Name              = name or "TextBox"
    b.Size              = UDim2.new(1,0,0,34)
    b.BackgroundColor3  = th.inputBg
    b.BorderSizePixel   = 0
    b.TextColor3        = th.accent
    b.TextSize          = 13
    b.Font              = Enum.Font.Gotham
    b.PlaceholderText   = placeholder or ""
    b.PlaceholderColor3 = th.subtext
    b.ClearTextOnFocus  = false
    b.TextXAlignment    = Enum.TextXAlignment.Left
    b.Parent            = parent
    addCorner(b, 8)
    addPadding(b, 10, 10, 0, 0)
    addStroke(b, Color3.fromRGB(80,80,100), 1, 0.5)
    return b
end


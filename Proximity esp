    {keywords={"npc","merchant","comerciante","vendor","vendedor","quest","missao","shop","loja"}, color=Color3.fromRGB(180,120,255), icon="[NPC]", label="NPCs"},
    {keywords={"potion","pocao","food","comida","ore","minerio","crystal","cristal","gem","gema","wood","madeira"}, color=Color3.fromRGB(100,220,100), icon="[REC]", label="Recursos"},
    {keywords={"sword","espada","weapon","arma","bow","arco","shield","escudo","armor","armadura","knife","faca"}, color=Color3.fromRGB(200,200,200), icon="[ARM]", label="Armas"},
    {keywords={"portal","teleporter","teletransportador"},                         color=Color3.fromRGB(0,255,220),   icon="[PORT]",   label="Portais"},
    {keywords={"forge","forja","anvil","bigorna","workbench","bancada","furnace","craft"}, color=Color3.fromRGB(255,140,60), icon="[CRAFT]", label="Crafting"},
}

local function getCategory(objectName)
    local lower = string.lower(objectName)
    lower = lower:gsub("á","a"):gsub("ã","a"):gsub("â","a"):gsub("é","e")
                 :gsub("ê","e"):gsub("í","i"):gsub("ó","o"):gsub("õ","o")
                 :gsub("ô","o"):gsub("ú","u"):gsub("ç","c")
    for _, cat in ipairs(categories) do
        for _, kw in ipairs(cat.keywords) do
            if lower:find(kw, 1, true) then
                return cat.color, cat.icon, cat.label
            end
        end
    end
    return Color3.fromRGB(0,255,0), "[OBJ]", "Outros"
end

-- ═══════════════════════════════════════════════════════════════
-- 🌐 TRADUÇÃO COM CACHE
-- ═══════════════════════════════════════════════════════════════
local translationCache = {}

local function translateText(text)
    if not text or text == "" then return "Objeto" end
    if translationCache[text] then return translationCache[text] end
    local lower = string.lower(text)
    if translations[lower] then
        translationCache[text] = translations[lower]
        return translations[lower]
    end
    local words = {}
    for word in string.gmatch(text, "%S+") do
        table.insert(words, translations[string.lower(word)] or word)
    end
    local result = table.concat(words, " ")
    translationCache[text] = result
    return result
end


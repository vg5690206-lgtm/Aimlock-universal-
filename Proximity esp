-- ═══════════════════════════════════════════════════════════════
-- 🔢 CONTADOR E STATS
-- ═══════════════════════════════════════════════════════════════
local function updateCounterAndStats()
    if not guiRef then return end
    local camPos    = camera.CFrame.Position
    local visible   = 0
    local catCounts = {}

    for _, espData in pairs(espObjects) do
        if espData.TargetPart and espData.TargetPart.Parent then
            local dist = (espData.TargetPart.Position - camPos).Magnitude
            if dist <= config.maxDistance then
                visible = visible + 1
                local lbl = espData.CatLabel
                catCounts[lbl] = (catCounts[lbl] or 0) + 1
            end
        end
    end

    if guiRef.counterLabel then
        guiRef.counterLabel.Text = "ESPs visiveis: " .. visible
    end

    if guiRef.statsContainer then
        for _, c in ipairs(guiRef.statsContainer:GetChildren()) do
            if c:IsA("TextLabel") and c.Name == "StatRow" then c:Destroy() end
        end
        local th = T()
        if visible == 0 then
            local row = Instance.new("TextLabel")
            row.Name = "StatRow"
            row.Size = UDim2.new(1,0,0,22)
            row.BackgroundTransparency = 1
            row.Text = "Nenhum objeto no alcance"
            row.TextColor3 = th.subtext
            row.TextSize = 12
            row.Font = Enum.Font.Gotham
            row.TextXAlignment = Enum.TextXAlignment.Left
            row.Parent = guiRef.statsContainer
        else
            local order = 1
            for catLabel, count in pairs(catCounts) do
                local icon = "[OBJ]"
                for _, cat in ipairs(categories) do
                    if cat.label == catLabel then icon = cat.icon break end
                end
                local row = Instance.new("TextLabel")
                row.Name = "StatRow"
                row.Size = UDim2.new(1,0,0,22)
                row.BackgroundTransparency = 1
                row.Text = icon .. " " .. catLabel .. ": " .. count
                row.TextColor3 = th.text
                row.TextSize = 13
                row.Font = Enum.Font.Gotham
                row.TextXAlignment = Enum.TextXAlignment.Left
                row.LayoutOrder = order
                row.Parent = guiRef.statsContainer
                order = order + 1
            end
        end
    end
end

-- ═══════════════════════════════════════════════════════════════
-- 🎨 CRIAR LABEL ESP
-- ═══════════════════════════════════════════════════════════════
local function createESPLabel(prompt)
    local targetPart = prompt.Parent
    if not targetPart:IsA("BasePart") then
        targetPart = targetPart:FindFirstChild("HumanoidRootPart")
                  or targetPart:FindFirstChildOfClass("BasePart")
    end
    if not targetPart then return nil end

    local objectName = prompt.ObjectText ~= "" and prompt.ObjectText or "Objeto"
    local actionText = prompt.ActionText ~= "" and prompt.ActionText or "Interagir"
    local keyText    = tostring(prompt.KeyboardKeyCode):gsub("Enum.KeyCode.","")

    objectName = translateText(objectName)
    actionText = translateText(actionText)

    local color, icon, catLabel = getCategory(objectName)

    local bill = Instance.new("BillboardGui")
    bill.Name        = "ESP_ProxPrompt"
    bill.Size        = UDim2.new(6,0,2,0)
    bill.MaxDistance = config.maxDistance
    bill.AlwaysOnTop = true
    bill.Enabled     = true
    bill.Parent      = targetPart

    local lbl = Instance.new("TextLabel")
    lbl.Name               = "ESPText"
    lbl.Size               = UDim2.new(1,0,1,0)
    lbl.BackgroundTransparency = 1
    lbl.TextColor3         = color
    lbl.TextSize           = 14
    lbl.Font               = Enum.Font.GothamBold
    lbl.TextScaled         = true
    lbl.TextWrapped        = true
    lbl.Text               = icon .. " " .. objectName .. "\n[" .. keyText .. "] " .. actionText
    lbl.Parent             = bill

    local stroke = Instance.new("UIStroke")
    stroke.Color     = Color3.fromRGB(0,0,0)
    stroke.Thickness = 2
    stroke.Parent    = lbl

    return {
        BillboardGui = bill,
        TextLabel    = lbl,
        TargetPart   = targetPart,
        Prompt       = prompt,
        ObjectName   = objectName,
        ActionText   = actionText,
        KeyText      = keyText,
        Color        = color,
        Icon         = icon,
        CatLabel     = catLabel,
    }
end

-- ═══════════════════════════════════════════════════════════════
-- ✅ ATIVAR / ❌ DESATIVAR
-- ═══════════════════════════════════════════════════════════════
local function deactivateESP()
    if not config.espEnabled then return end
    config.espEnabled = false
    for _, espData in pairs(espObjects) do
        if espData.BillboardGui.Parent then
            espData.BillboardGui:Destroy()
        end
    end
    espObjects       = {}
    monitoredPrompts = {}
    updateCounterAndStats()
end

local function activateESP()
    if config.espEnabled then deactivateESP() end
    config.espEnabled = true
    for _, prompt in ipairs(findAllProximityPrompts()) do
        if prompt.Parent and prompt.Parent.Parent then
            local objectName = prompt.ObjectText ~= "" and prompt.ObjectText or "Objeto"
            if matchesFilter(objectName) then
                local espData = createESPLabel(prompt)
                if espData then
                    espObjects[prompt]       = espData
                    monitoredPrompts[prompt] = true
                end
            end
        end
    end
    updateCounterAndStats()
end

-- ═══════════════════════════════════════════════════════════════
-- 🔄 MONITOR NOVOS (a cada 0.5s)
-- ═══════════════════════════════════════════════════════════════
local function monitorNewPrompts()
    if not config.espEnabled then return end
    local changed = false

    for _, prompt in ipairs(findAllProximityPrompts()) do
        if not monitoredPrompts[prompt] and prompt.Parent and prompt.Parent.Parent then
            local objectName = prompt.ObjectText ~= "" and prompt.ObjectText or "Objeto"
            if matchesFilter(objectName) then
                local espData = createESPLabel(prompt)
                if espData then
                    espObjects[prompt]       = espData
                    monitoredPrompts[prompt] = true
                    changed = true
                end
            end
        end
    end

    local toRemove = {}
    for prompt, espData in pairs(espObjects) do
        if not prompt.Parent or not prompt.Parent.Parent then
            if espData.BillboardGui.Parent then espData.BillboardGui:Destroy() end
            table.insert(toRemove, prompt)
            changed = true
        end
    end
    for _, p in ipairs(toRemove) do
        espObjects[p] = nil
        monitoredPrompts[p] = nil
    end

    if changed then updateCounterAndStats() end
end

-- ═══════════════════════════════════════════════════════════════
-- 📏 ATUALIZAR TAMANHO — só dentro da distância
-- ═══════════════════════════════════════════════════════════════
local statsTimer = 0

local function updateDynamicSize(dt)
    if not config.espEnabled then return end
    local camPos = camera.CFrame.Position
    local time   = tick()

    statsTimer = statsTimer + dt
    local doStats = statsTimer >= 1
    if doStats then statsTimer = 0 end

    for prompt, espData in pairs(espObjects) do
        local part = espData.TargetPart
        if part and part.Parent then
            local dist = (part.Position - camPos).Magnitude

            if dist > config.maxDistance then
                espData.BillboardGui.Enabled = false
            else
                espData.BillboardGui.Enabled = true

                local t  = math.clamp(dist / config.maxDistance, 0, 1)
                local sz = 2.5 + t * 5.5
                espData.BillboardGui.Size = UDim2.new(sz, 0, sz * 0.4, 0)

                local alpha = 1
                if dist < 20 then
                    alpha = 0.5 + 0.5 * math.sin(time * 6)
                end
                espData.TextLabel.TextTransparency = 1 - alpha

                if config.showDistance then
                    espData.TextLabel.Text = espData.Icon .. " " .. espData.ObjectName
                        .. "\n[" .. espData.KeyText .. "] " .. espData.ActionText
                        .. " | " .. math.floor(dist) .. "m"
                else
                    espData.TextLabel.Text = espData.Icon .. " " .. espData.ObjectName
                        .. "\n[" .. espData.KeyText .. "] " .. espData.ActionText
                end
            end
        else
            if espData.BillboardGui.Parent then espData.BillboardGui:Destroy() end
            espObjects[prompt]       = nil
            monitoredPrompts[prompt] = nil
        end
    end

    if doStats then updateCounterAndStats() end
end


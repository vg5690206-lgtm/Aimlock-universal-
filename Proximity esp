        th.tabSel, Color3.fromRGB(0,0,0), UDim2.new(0,90,0,28), "ESPButton")

    local FilterButton = makeButton(TabsFrame, "FILTRO",
        th.btnBg, th.text, UDim2.new(0,90,0,28), "FilterButton")

    local InfoButton = makeButton(TabsFrame, "INFO",
        th.btnBg, th.text, UDim2.new(0,90,0,28), "InfoButton")

    -- ESPFrame
    local ESPFrame = makeFrame(MainFrame,
        UDim2.new(1,0,1,-82),
        UDim2.new(0,0,0,82),
        th.bg, "ESPFrame")
    ESPFrame.Visible = true
    addListLayout(ESPFrame, 8)
    addPadding(ESPFrame, 12, 12, 10, 10)

    makeSectionLabel(ESPFrame, "CONTROLO")
    local ativarBtn = makeButton(ESPFrame, "ATIVAR ESP  (F5)",
        th.btnBg, Color3.fromRGB(255,255,255), UDim2.new(1,0,0,40), "AtivarBtn")
    ativarBtn.TextSize = 14

    makeSectionLabel(ESPFrame, "DISTANCIA MAXIMA")
    local distLabel = makeLabel(ESPFrame, "Distancia: " .. config.maxDistance .. "m", th.text, 13)

    local sliderFrame = makeFrame(ESPFrame,
        UDim2.new(1,0,0,36), nil, th.inputBg, "SliderFrame")
    addCorner(sliderFrame, 8)

    local btnMinus = makeButton(sliderFrame, "-",
        th.danger, Color3.fromRGB(255,255,255), UDim2.new(0,44,1,0), "BtnMinus")
    btnMinus.Position = UDim2.new(0,0,0,0)
    btnMinus.TextSize = 20

    local sliderVal = Instance.new("TextLabel")
    sliderVal.Name               = "SliderVal"
    sliderVal.Size               = UDim2.new(1,-88,1,0)
    sliderVal.Position           = UDim2.new(0,44,0,0)
    sliderVal.BackgroundTransparency = 1
    sliderVal.Text               = tostring(config.maxDistance) .. "m"
    sliderVal.TextColor3         = th.text
    sliderVal.TextSize           = 13
    sliderVal.Font               = Enum.Font.GothamBold
    sliderVal.TextXAlignment     = Enum.TextXAlignment.Center
    sliderVal.Parent             = sliderFrame

    local btnPlus = makeButton(sliderFrame, "+",
        th.accent, Color3.fromRGB(0,0,0), UDim2.new(0,44,1,0), "BtnPlus")
    btnPlus.Position = UDim2.new(1,-44,0,0)
    btnPlus.TextSize = 20

    local showDistBtn = makeButton(ESPFrame, "VER DISTANCIA: ON",
        th.info, Color3.fromRGB(255,255,255), UDim2.new(1,0,0,36), "ShowDistBtn")

    makeSectionLabel(ESPFrame, "POSICAO DA JANELA")
    local cornersRow = makeFrame(ESPFrame,
        UDim2.new(1,0,0,36), nil, th.bg, "CornersRow")
    cornersRow.BackgroundTransparency = 1
    addListLayout(cornersRow, 4, Enum.FillDirection.Horizontal)

    local cornerDefs = {
        {text="TL", pos=UDim2.new(0,10,0,10)},
        {text="TR", pos=UDim2.new(1,-350,0,10)},
        {text="BL", pos=UDim2.new(0,10,1,-510)},
        {text="BR", pos=UDim2.new(1,-350,1,-510)},
    }
    local cornerBtns = {}
    for i, d in ipairs(cornerDefs) do
        local cb = makeButton(cornersRow, d.text,
            th.btnBg, th.text, UDim2.new(0,70,0,36), "Corner"..i)
        cornerBtns[i] = {btn=cb, pos=d.pos}
    end

    -- FilterFrame
    local FilterFrame = makeFrame(MainFrame,
        UDim2.new(1,0,1,-82),
        UDim2.new(0,0,0,82),
        th.bg, "FilterFrame")
    FilterFrame.Visible = false
    addListLayout(FilterFrame, 8)
    addPadding(FilterFrame, 12, 12, 10, 10)

    makeSectionLabel(FilterFrame, "FILTRAR POR NOME (EN ou PT)")
    local filterInput = makeTextBox(FilterFrame, "Ex: chest, bau, door, porta...", "FilterInput")

    local filterBtnRow = makeFrame(FilterFrame,
        UDim2.new(1,0,0,36), nil, th.bg, "FilterBtnRow")
    filterBtnRow.BackgroundTransparency = 1
    addListLayout(filterBtnRow, 6, Enum.FillDirection.Horizontal)

    local applyBtn = makeButton(filterBtnRow, "APLICAR",
        th.info, Color3.fromRGB(255,255,255), UDim2.new(0,148,0,36), "ApplyBtn")

    local clearBtn = makeButton(filterBtnRow, "LIMPAR",
        th.danger, Color3.fromRGB(255,255,255), UDim2.new(0,148,0,36), "ClearBtn")

    local statusFilterLabel = makeLabel(FilterFrame, "", th.accent, 12,
        Enum.Font.Gotham, "StatusFilterLabel")
    statusFilterLabel.Size = UDim2.new(1,0,0,18)

    makeSectionLabel(FilterFrame, "HISTORICO (clique para usar)")
    local histContainer = makeFrame(FilterFrame,
        UDim2.new(1,0,0,36), nil, th.inputBg, "HistContainer")
    addCorner(histContainer, 8)
    addPadding(histContainer, 8, 8, 6, 6)
    addListLayout(histContainer, 4)

    local emptyHistLabel = makeLabel(histContainer,
        "Nenhum filtro usado ainda", th.subtext, 11, Enum.Font.Gotham, "EmptyHist")
    emptyHistLabel.Size = UDim2.new(1,0,0,18)

    -- InfoFrame
    local InfoFrame = makeFrame(MainFrame,
        UDim2.new(1,0,1,-82),
        UDim2.new(0,0,0,82),
        th.bg, "InfoFrame")
    InfoFrame.Visible = false
    addListLayout(InfoFrame, 8)
    addPadding(InfoFrame, 12, 12, 10, 10)

    makeSectionLabel(InfoFrame, "STATUS")
    local counterLabel = makeLabel(InfoFrame, "ESPs visiveis: 0",
        th.accent, 13, Enum.Font.GothamBold, "CounterLabel")
    local statusLabel = makeLabel(InfoFrame, "ESP Desativado",
        th.danger, 13, Enum.Font.Gotham, "StatusLabel")

    makeSectionLabel(InfoFrame, "OBJETOS POR CATEGORIA")
    local statsContainer = makeFrame(InfoFrame,
        UDim2.new(1,0,0,36), nil, th.inputBg, "StatsContainer")
    addCorner(statsContainer, 8)
    addPadding(statsContainer, 10, 10, 6, 6)
    local statsLayout = addListLayout(statsContainer, 3)
    statsLayout.Changed:Connect(function()
        statsContainer.Size = UDim2.new(1,0,0,
            math.max(36, statsLayout.AbsoluteContentSize.Y + 12))
    end)

    makeSectionLabel(InfoFrame, "VERSAO")
    makeLabel(InfoFrame, "v4.0 — F5 para ativar/desativar", th.subtext, 11)

    guiRef = {
        counterLabel   = counterLabel,
        statsContainer = statsContainer,
    }

    -- ════════════════════════════════════════════════════════════
    -- SISTEMA DE ABAS
    -- ════════════════════════════════════════════════════════════
    local tabs = {
        {btn=ESPButton,    frame=ESPFrame},
        {btn=FilterButton, frame=FilterFrame},
        {btn=InfoButton,   frame=InfoFrame},
    }

    local function switchTab(idx)
        for i, tab in ipairs(tabs) do
            tab.frame.Visible = (i == idx)
            if i == idx then
                tab.btn.BackgroundColor3 = th.tabSel
                tab.btn.TextColor3       = Color3.fromRGB(0,0,0)
            else
                tab.btn.BackgroundColor3 = th.btnBg
                tab.btn.TextColor3       = th.text
            end
        end
    end

    ESPButton.MouseButton1Click:Connect(function()    switchTab(1) end)
    FilterButton.MouseButton1Click:Connect(function() switchTab(2) end)
    InfoButton.MouseButton1Click:Connect(function()
        updateCounterAndStats()
        switchTab(3)
    end)

    -- ════════════════════════════════════════════════════════════
    -- FUNÇÕES DE UI
    -- ════════════════════════════════════════════════════════════
    local function setESPState(on)
        if on then
            ativarBtn.BackgroundColor3 = th.accent
            ativarBtn.Text             = "DESATIVAR ESP  (F5)"
            ativarBtn.TextColor3       = Color3.fromRGB(0,0,0)
            statusLabel.Text           = "ESP Ativado"
            statusLabel.TextColor3     = th.accent
        else
            ativarBtn.BackgroundColor3 = th.btnBg
            ativarBtn.Text             = "ATIVAR ESP  (F5)"
            ativarBtn.TextColor3       = Color3.fromRGB(255,255,255)
            statusLabel.Text           = "ESP Desativado"
            statusLabel.TextColor3     = th.danger
        end
    end

    local function addToHistory(text)
        if text == "" then return end
        for _, e in ipairs(config.filterHistory) do
            if e == text then return end
        end
        table.insert(config.filterHistory, 1, text)
        if #config.filterHistory > 5 then table.remove(config.filterHistory) end

        for _, c in ipairs(histContainer:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        emptyHistLabel.Visible = #config.filterHistory == 0

        for idx, entry in ipairs(config.filterHistory) do
            local hBtn = Instance.new("TextButton")
            hBtn.Name               = "HistBtn"
            hBtn.Size               = UDim2.new(1,0,0,20)
            hBtn.BackgroundTransparency = 1
            hBtn.Text               = ">> " .. entry
            hBtn.TextColor3         = th.subtext
            hBtn.TextSize           = 12
            hBtn.Font               = Enum.Font.Gotham
            hBtn.TextXAlignment     = Enum.TextXAlignment.Left
            hBtn.LayoutOrder        = idx
            hBtn.Parent             = histContainer
            hBtn.MouseButton1Click:Connect(function()
                filterInput.Text = entry
            end)
        end
        histContainer.Size = UDim2.new(1,0,0,
            math.max(36, #config.filterHistory * 24 + 12))
    end

    -- ════════════════════════════════════════════════════════════
    -- EVENTOS
    -- ════════════════════════════════════════════════════════════
    ativarBtn.MouseButton1Click:Connect(function()
        if not config.espEnabled then
            activateESP()
            setESPState(true)
        else
            deactivateESP()
            setESPState(false)
        end
    end)

    btnMinus.MouseButton1Click:Connect(function()
        config.maxDistance = math.max(50, config.maxDistance - 50)
        sliderVal.Text   = tostring(config.maxDistance) .. "m"
        distLabel.Text   = "Distancia: " .. config.maxDistance .. "m"
        for _, e in pairs(espObjects) do
            e.BillboardGui.MaxDistance = config.maxDistance
        end
        updateCounterAndStats()
    end)

    btnPlus.MouseButton1Click:Connect(function()
        config.maxDistance = math.min(2000, config.maxDistance + 50)
        sliderVal.Text   = tostring(config.maxDistance) .. "m"
        distLabel.Text   = "Distancia: " .. config.maxDistance .. "m"
        for _, e in pairs(espObjects) do
            e.BillboardGui.MaxDistance = config.maxDistance
        end
        updateCounterAndStats()
    end)

    showDistBtn.MouseButton1Click:Connect(function()
        config.showDistance = not config.showDistance
        showDistBtn.Text = config.showDistance
            and "VER DISTANCIA: ON"
            or  "VER DISTANCIA: OFF"
    end)

    for _, d in ipairs(cornerBtns) do
        d.btn.MouseButton1Click:Connect(function()
            MainFrame.Position = d.pos
        end)
    end

    applyBtn.MouseButton1Click:Connect(function()
        local raw = filterInput.Text:match("^%s*(.-)%s*$")
        config.filterText = raw
        addToHistory(raw)

        local matchCount = 0
        for _, prompt in ipairs(findAllProximityPrompts()) do
            local objectName = prompt.ObjectText ~= "" and prompt.ObjectText or "Objeto"
            if matchesFilter(objectName) then matchCount = matchCount + 1 end
        end

        if raw ~= "" and matchCount == 0 then
            statusFilterLabel.Text       = "Nenhum resultado para: " .. raw
            statusFilterLabel.TextColor3 = th.danger
        else
            statusFilterLabel.Text       = raw == ""
                and "Sem filtro — mostrando tudo"
                or  matchCount .. " objeto(s) encontrado(s)"
            statusFilterLabel.TextColor3 = th.accent
        end

        if config.espEnabled then
            activateESP()
            setESPState(true)
        end
    end)

    clearBtn.MouseButton1Click:Connect(function()
        filterInput.Text             = ""
        config.filterText            = ""
        statusFilterLabel.Text       = "Filtro limpo — mostrando tudo"
        statusFilterLabel.TextColor3 = th.accent
        if config.espEnabled then
            activateESP()
            setESPState(true)
        end
    end)

    themeBtn.MouseButton1Click:Connect(function()
        config.darkTheme = not config.darkTheme
        screenGui:Destroy()
        guiRef = nil
        createMainGUI()
    end)

    local isMinimized = false
    minimizeBtn.MouseButton1Click:Connect(function()
        isMinimized = not isMinimized
        if isMinimized then
            MainFrame.Size      = UDim2.new(0,340,0,46)
            TabsFrame.Visible   = false
            ESPFrame.Visible    = false
            FilterFrame.Visible = false
            InfoFrame.Visible   = false
            minimizeBtn.Text    = "+"
        else
            MainFrame.Size    = UDim2.new(0,340,0,500)
            TabsFrame.Visible = true
            switchTab(1)
            minimizeBtn.Text  = "-"
        end
    end)

    closeBtn.MouseButton1Click:Connect(function()
        deactivateESP()
        screenGui:Destroy()
        guiRef = nil
    end)

    local dragging, dragStart, startPos = false, nil, nil
    HeaderFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging  = true
            dragStart = input.Position
            startPos  = MainFrame.Position
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            MainFrame.Position = startPos + UDim2.new(0,delta.X,0,delta.Y)
        end
    end)

    return screenGui
end


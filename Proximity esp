-- ⌨️ TECLA F5
-- ═══════════════════════════════════════════════════════════════
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.F5 then
        if not config.espEnabled then
            activateESP()
        else
            deactivateESP()
        end
        updateCounterAndStats()
    end
end)


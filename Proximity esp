-- 🔍 FILTRO
-- ═══════════════════════════════════════════════════════════════
local function matchesFilter(objectName)
    if config.filterText == "" then return true end
    local f  = string.lower(config.filterText)
    local n  = string.lower(objectName)
    local nt = string.lower(translateText(objectName))
    return n:find(f,1,true) ~= nil or nt:find(f,1,true) ~= nil
end

